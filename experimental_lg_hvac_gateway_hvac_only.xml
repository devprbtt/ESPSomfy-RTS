<?xml version="1.0" encoding="UTF-8"?>
<component xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="racepoint_component_profile.xsd"
           manufacturer="devprbtt Experimental"
           model="LGHVACGatewayHVACOnly"
           alias="Experimental LG HVAC Gateway"
           device_class="HVAC_controller"
           rpm_xml_version="2.2"
           minimum_component_engine_version="8.10">

    <notes>
        Experimental HVAC-only Savant profile for use with the Python helper.
        This file avoids lighting and shade resources so it does not interfere
        with working XML profiles or trigger unrelated Blueprint service generation.
        Target helper default:
        - IP: Savant host IP
        - Port: 2323
    </notes>

    <control_interfaces preferred="ip">
        <ip port="2323" response_time_length_ms="1000" name_on_component="Ethernet">
            <send_postfix type="hex">0D0A</send_postfix>
            <receive_end_condition test_condition="data" type="hex">0D0A</receive_end_condition>
        </ip>
    </control_interfaces>

    <media_interfaces>
        <data name_on_component="Ethernet">
            <combined_media>
                <data_media type="ethernet"/>
                <control port="2323"/>
            </combined_media>
        </data>

        <internal name_on_component="HVAC Controller">
            <environmental_media/>
            <resource resource_type="ENV_SINGLE_SETPOINT_HVACCONTROLLER_SOURCE"/>
        </internal>
    </media_interfaces>

    <state_variable_list>
        <state_variable name="Current_Set_Point_Setting"
                        owning_logical_component="HVAC_controller"
                        state_center_type="string"
                        state_center_binding="ThermostatCurrentSetPoint"></state_variable>
    </state_variable_list>

    <logical_component logical_component_name="HVAC_controller">
        <implementation>
            <internal name_on_component="HVAC Controller"/>
        </implementation>

        <status_messages>
            <status_message name="CurrentThermostatCoolPoint">
                <constant type="character">R:HVAC COOLPOINT </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatCurrentSetPoint" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress" note="'1' - '999999'"/>
            </status_message>

            <status_message name="CurrentThermostatSetPoint">
                <constant type="character">R:HVAC SETPOINT </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatCurrentSetPoint" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress" note="'1' - '999999'"/>
            </status_message>

            <status_message name="CurrentThermostatHeatPoint">
                <constant type="character">R:HVAC HEATPOINT </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatCurrentSetPoint" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress" note="'1' - '999999'"/>
            </status_message>

            <status_message name="ThermostatCurrentRemoteTemperature">
                <constant type="character">R:HVAC EXTERNALTEMP </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatCurrentRemoteTemperature" type="string"></update>
                    <update state="ThermostatCurrentSetPoint" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress"/>
            </status_message>

            <status_message name="ThermostatCurrentTemperature">
                <constant type="character">R:HVAC CURRENTTEMP </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatCurrentTemperature" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress" note="'1' - '999999'"/>
            </status_message>

            <status_message name="CurrentThermostatMode">
                <constant type="character">R:HVAC </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <data_map match_required="yes">
                        <map key="COOL">
                            <update state="IsCurrentHVACModeHeat" type="boolean">false</update>
                            <update state="IsCurrentHVACModeCool" type="boolean">true</update>
                            <update state="IsCurrentHVACModeAuto" type="boolean">false</update>
                            <update state="IsThermostatCurrentFanModeOn" type="boolean">false</update>
                            <update state="IsCurrentHVACModeOff" type="boolean">false</update>
                        </map>
                        <map key="HEAT">
                            <update state="IsCurrentHVACModeHeat" type="boolean">true</update>
                            <update state="IsCurrentHVACModeCool" type="boolean">false</update>
                            <update state="IsCurrentHVACModeAuto" type="boolean">false</update>
                            <update state="IsThermostatCurrentFanModeOn" type="boolean">false</update>
                            <update state="IsCurrentHVACModeOff" type="boolean">false</update>
                        </map>
                        <map key="FAN">
                            <update state="IsCurrentHVACModeHeat" type="boolean">false</update>
                            <update state="IsCurrentHVACModeCool" type="boolean">false</update>
                            <update state="IsCurrentHVACModeAuto" type="boolean">false</update>
                            <update state="IsThermostatCurrentFanModeOn" type="boolean">true</update>
                            <update state="IsCurrentHVACModeOff" type="boolean">false</update>
                        </map>
                        <map key="OFF">
                            <update state="IsCurrentHVACModeHeat" type="boolean">false</update>
                            <update state="IsCurrentHVACModeCool" type="boolean">false</update>
                            <update state="IsCurrentHVACModeAuto" type="boolean">false</update>
                            <update state="IsThermostatCurrentFanModeOn" type="boolean">false</update>
                            <update state="IsCurrentHVACModeOff" type="boolean">true</update>
                        </map>
                    </data_map>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress" note="'1' - '999999'"/>
            </status_message>

            <status_message name="CurrentThermostatFanMode">
                <constant type="character">R:HVAC </constant>
                <data type="character" terminator_type="character" terminator=" ">
                    <data_map match_required="yes">
                        <map key="FANHIGH">
                            <update state="ThermostatCurrentFanModeIsLow" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsMed" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsHigh" type="boolean">true</update>
                            <update state="ThermostatCurrentFanModeIsAuto" type="boolean">false</update>
                        </map>
                        <map key="FANMID">
                            <update state="ThermostatCurrentFanModeIsLow" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsMed" type="boolean">true</update>
                            <update state="ThermostatCurrentFanModeIsHigh" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsAuto" type="boolean">false</update>
                        </map>
                        <map key="FANLOW">
                            <update state="ThermostatCurrentFanModeIsLow" type="boolean">true</update>
                            <update state="ThermostatCurrentFanModeIsMed" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsHigh" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsAuto" type="boolean">false</update>
                        </map>
                        <map key="FANAUTO">
                            <update state="ThermostatCurrentFanModeIsLow" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsMed" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsHigh" type="boolean">false</update>
                            <update state="ThermostatCurrentFanModeIsAuto" type="boolean">true</update>
                        </map>
                    </data_map>
                </data>
                <data type="character" terminator_type="end_of_data">
                    <update state="ThermostatAddress" type="string"></update>
                </data>
                <append_data_to_state_names state="ThermostatAddress" note="'1' - '999999'"/>
            </status_message>
        </status_messages>

        <resource_component_actions resource_type="ENV_SINGLE_SETPOINT_HVACCONTROLLER_SOURCE">
            <action name="SetSingleSetPointTemperature">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <action_argument name="SetPointTemperature" note="Select the Temperature Point 06 - 33 Celsius"/>
                <update_state_variable name="Current_Set_Point_Setting" update_type="set" update_source="action_argument">SetPointTemperature</update_state_variable>
                <command_interface interface="ip">
                    <command response_required="no" partial_response="no">
                        <command_string type="character">HVAC SETPOINT </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                            <parameter parameter_data_type="character"> </parameter>
                            <parameter parameter_data_type="character" state_variable="Current_Set_Point_Setting" parameter_data_width="2" parameter_total_width="2" parameter_fill="0" parameter_justify="right"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetHVACModeHeat">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC HEAT </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetHVACModeCool">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC COOL </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetHVACModeOff">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC OFF </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetFanSpeedHigh">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC FANHIGH </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetFanSpeedMid">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC FANMID </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetFanSpeedLow">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC FANLOW </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <action name="SetFanSpeedAuto">
                <action_argument name="ThermostatAddress" note="DEVICE_ID"/>
                <action_argument name="ThermostatAddress2" note="not used"/>
                <command_interface interface="ip">
                    <command response_required="no">
                        <command_string type="character">HVAC FANAUTO </command_string>
                        <parameter_list>
                            <parameter parameter_data_type="character" action_argument="ThermostatAddress"></parameter>
                        </parameter_list>
                        <delay ms_delay="100"/>
                    </command>
                </command_interface>
            </action>

            <entity name="Zone" address_components="2" max_entities="1">
                <screen_representation>
                    <common_unique_identifier name="ThermostatAddress" address_component="1"/>
                    <common_unique_identifier name="ThermostatAddress2" address_component="2"/>
                </screen_representation>
            </entity>
        </resource_component_actions>
    </logical_component>
</component>
